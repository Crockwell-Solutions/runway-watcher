{
  "name": "runway-watcher",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "frontend",
    "infrastructure",
    "backend"
  ],
  "scripts": {
    "frontend": "npm run dev -w frontend",
    "build:backend": "node_modules/.bin/esbuild --bundle backend/*.ts --outdir=dist/ --sourcemap=inline --platform=node && cp -r resources/camera-images/* dist/files",
    "build:frontend": "npm run build -w frontend",
    "build:infra": "npm run build -w infrastructure",
    "lint": "npm run lint -w frontend",
    "synth": "npm run synth -w infrastructure",
    "deploy": "npm run deploy -w infrastructure",
    "deploy:backend": "npm run deploy:backend -w infrastructure",
    "deploy:frontend": "npm run deploy:frontend -w infrastructure",
    "test:infra": "npm run test -w infrastructure",
    "cdk": "npm run cdk -w infrastructure --"
  }
}
